-- All the items in a single container regardless of the relationships
SELECT I.name, I.owned_by, I.created_at, I.quantity
    FROM Objects o INNER JOIN Items I on o.id = I.owned_by
WHERE o.owner_id = (SELECT id FROM Objects WHERE id = 'obj1') OR I.owned_by = 'obj1' ORDER BY owned_by
LIMIT 1000;


SELECT obj.name, obj.owner_id FROM Objects obj Where obj.owner_id is not NULL ORDER BY obj.owner_id
Limit 10;

UPDATE Objects SET owner_id = 'obj1' WHERE id = 'obj3';

-- All items from the current container up to the root container (only along the direct route to the parent)
WITH RECURSIVE ItemPath(n) AS (
    VALUES ('obj5')
    UNION
    SELECT owner_id FROM Objects, ItemPath WHERE Objects.id = ItemPath.n AND Objects.owner_id IS NOT NULL
    LIMIT 1000
) SELECT Items.name FROM Items WHERE owned_by IN ItemPath;